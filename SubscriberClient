import sys
import threading
import time
import socket
from parking_client import ParkingRPCClient

HOST = '127.0.0.1'
PORT = 8082

def listenEvents(subId, lotId):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.connect((HOST, PORT))
            s.sendall(f"ATTACH {subId}\n".encode())
            response = s.recv(1024).decode().strip()
            if not response.startswith("OK"):
                  return
            buf = ""
            while True:
                  data = s.recv(1024)
                  if not data:
                        break
                  buf += data.decode()
                  while "\n" in buf:
                        line, buf = buf.split("\n", 1)
                        line = line.strip()
                        if line != "PING":
                              print(line)

if __name__ == "__main__":
      client = ParkingRPCCClient(HOST, PORT)
      subIds = []

      for lot in sys.argv[1:]:
            subId = client._call("subscribe", [lot])
            subIds.append((lot, subId))
            t = threading.Thread(target = listenEvents, args = (subId, lot))
            t.start()
            print(f"Subscribed to {lot}\nSubID = {subId}")
